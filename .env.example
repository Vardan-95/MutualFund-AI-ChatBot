# =============================================================================
# Mutual Fund FAQ — environment variables (copy to .env and fill in)
#   copy .env.example .env
# Never commit .env — it is listed in .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# 1) Chroma Cloud — application (Python ingest + RAG API)
#    From https://www.trychroma.com/ → your database → Connect
#    Used by: python -m jobs.ingest, GitHub Actions (CHROMA_API_KEY secret)
# -----------------------------------------------------------------------------
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
# Optional — only if Connect panel shows a regional host (not api.trychroma.com)
# CHROMA_HOST=api.trychroma.com

# -----------------------------------------------------------------------------
# 2) Chroma CLI — login (terminal: chroma login)
#    Create a second API key in the dashboard if you want CLI separate from the app,
#    or paste the same key as CHROMA_API_KEY if you only have one.
#
#    Login (PowerShell, from project root after filling .env):
#      $env:CHROMA_CLI_API_KEY = (Get-Content .env | Where-Object { $_ -match '^CHROMA_CLI_API_KEY=' }) -replace '^CHROMA_CLI_API_KEY=',''
#      chroma login --profile mutual-fund --api-key $env:CHROMA_CLI_API_KEY
# -----------------------------------------------------------------------------
CHROMA_CLI_API_KEY=

# -----------------------------------------------------------------------------
# LLM — Groq (default for P1 answers). Get key: https://console.groq.com/
# Without GROQ_API_KEY (or OPENAI_API_KEY), extractive fallback is used.
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# LLM_PROVIDER=groq

# Optional — OpenAI instead of Groq (set OPENAI_API_KEY; Groq takes priority if both set)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Phase 7 — refusal education link (default: AMFI investor education)
# -----------------------------------------------------------------------------
# EDUCATIONAL_URL=https://www.amfiindia.com/investor/knowledge-center-info?zoneName=IntroductionToMF

# -----------------------------------------------------------------------------
# Phase 8 — multi-thread chat (SQLite)
# -----------------------------------------------------------------------------
# THREAD_DB_PATH=data/threads/threads.db
# THREAD_MAX_TURNS=4
# THREAD_EXPAND_QUERY=true

# -----------------------------------------------------------------------------
# Phase 9 — API server (python -m runtime.phase_9_api)
# -----------------------------------------------------------------------------
# PORT=8080
# API_HOST=127.0.0.1
# On Render (PORT is set automatically), API_HOST defaults to 0.0.0.0 if unset.
# RUNTIME_API_DEBUG=0
# ADMIN_REINDEX_SECRET=
# API_CORS_ORIGINS=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8080

# -----------------------------------------------------------------------------
# Optional — override embedding settings (defaults in config/embedding.yaml)
# -----------------------------------------------------------------------------
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DIMENSIONS=384
